# ── Slack ───────────────────────────────────────────────────
# Slack Bot Token (xoxb-로 시작)
# 발급: https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# 에스컬레이션 알림을 받을 Slack 채널 (예: #cs-escalation)
SLACK_ALERT_CHANNEL=#cs-escalation

# ── 채널톡 ─────────────────────────────────────────────────
# 채널톡 Webhook Secret (서명 검증용)
# 발급: 채널톡 관리자 → 개발자 도구 → Webhook
CHANNELTALK_WEBHOOK_SECRET=your-channeltalk-webhook-secret

# ── 서버 ────────────────────────────────────────────────────
PORT=5000
FLASK_ENV=production
